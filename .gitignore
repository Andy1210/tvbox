# dependencies
node_modules/

# the app registry - a SEPARATE repo (github.com/Andy1210/tvbox-apps), cloned
# here so everything's in one place. Has its own git; not tracked by core.
tvbox-apps/

# build output + generated bundles (regenerated by the launcher build / on the box)
shell/launcher-dist/
launcher/dist/
launcher/dist-demo/
launcher/.vite/
shell/apps-data/
shell/electron-web-client/

# python cache (CEC bridge)
__pycache__/
*.pyc

# logs & OS cruft
*.log
.DS_Store

# make-release output
dist/

# pi-gen stage payload - assembled by CI / local builds (docs/sd-image.md)
image/stage-tvbox/01-tvbox/files/

# local image build workdir (scripts/build-image.sh)
.image-build/
